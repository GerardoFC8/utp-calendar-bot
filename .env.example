# === UTP+ Class (Peru) ===
# Tu codigo de alumno (ej: 1234567890)
UTP_USERNAME=tu_codigo_de_alumno
# Tu contrasena institucional (la misma que usas para todas las plataformas UTP)
UTP_PASSWORD=tu_contrasena
UTP_BASE_URL=https://class.utp.edu.pe
# Rutas internas de la SPA (ajustar si cambian)
UTP_CALENDAR_PATH=/student/calendar
UTP_COURSES_PATH=/student/courses

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=987654321

# === Scheduler ===
# Cada cuanto scrapeamos (cron expression)
SCRAPE_CRON=0 */6 * * *
# Recordatorio matutino (6 AM de lunes a sabado, hora Lima)
MORNING_REMINDER_CRON=0 6 * * 1-6
# Minutos antes de la clase para enviar recordatorio
CLASS_REMINDER_MINUTES=30

# === Database ===
DATABASE_PATH=./data/utp.db

# === App ===
# Timezone local (Lima, Peru)
TZ=America/Lima
# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
# Modo: production | development
NODE_ENV=production
 